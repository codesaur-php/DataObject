{
    "name": "codesaur/dataobject",
    "description": "codesaur-php экосистемийн өгөгдлийн давхаргын үндсэн компонент, өгөгдлийн модель ба хүснэгтүүдийг удирдагч (MySQL / PostgreSQL / SQLite, PHP 8.2+)",
    "keywords": [
        "pdo", "database", "mysql", "postgres", "pgsql", "sqlite", "dataobject", "mongol", "mongolia", "монгол", "codesaur", "narankhuu", "coden", "кодзавр", "наранхүү", "коден"
    ],
    "homepage": "https://github.com/codesaur-php",
    "authors": [
        {
            "name": "Narankhuu (+976 99000287)",
            "email": "codesaur@gmail.com",
            "homepage": "https://github.com/codesaur"
        }
    ],
    "require": {
        "php": ">=8.2.1",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "codesaur\\DataObject\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "codesaur\\DataObject\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "license": "MIT",
    "minimum-stability": "dev"
